#!/usr/bin/env bash
# xcind-workspace — Manage xcind workspaces
#
# Usage:
#   xcind-workspace init [DIR] [OPTIONS]   Initialize a workspace directory
#   xcind-workspace status [DIR] [OPTIONS] Show workspace-wide status

set -euo pipefail

# Resolve XCIND_ROOT by following symlinks to the real install directory
# (npm, nix profile, and manual symlinks all route through here). macOS
# lacks `readlink -f`, so the resolver is a manual loop.
# Keep in sync with the equivalent stub in the other bin/ scripts.
__xcind_src="${BASH_SOURCE[0]}"
while [ -L "$__xcind_src" ]; do
  __xcind_src_dir=$(cd "$(dirname "$__xcind_src")" && pwd)
  __xcind_src=$(readlink "$__xcind_src")
  [[ $__xcind_src != /* ]] && __xcind_src="$__xcind_src_dir/$__xcind_src"
done
XCIND_ROOT="$(cd "$(dirname "$__xcind_src")/.." && pwd)"
unset __xcind_src __xcind_src_dir
# shellcheck disable=SC1091
source "$XCIND_ROOT/lib/xcind/xcind-bootstrap.bash"

if [[ ${1:-} == "--version" ]] || [[ ${1:-} == "-V" ]]; then
  echo "xcind-workspace ${XCIND_VERSION}"
  exit 0
fi

# --------------------------------------------------------------------------
# Init
# --------------------------------------------------------------------------

__xcind-workspace-write-config() {
  local dir="$1"
  local ws_name="${2:-}"
  local proxy_domain="${3:-}"

  local content='# shellcheck shell=bash
# shellcheck disable=SC2034
XCIND_IS_WORKSPACE=1'

  if [[ -n "$ws_name" ]]; then
    content+=$'\n'"XCIND_WORKSPACE=\"$ws_name\""
  fi
  if [[ -n "$proxy_domain" ]]; then
    content+=$'\n'"XCIND_PROXY_DOMAIN=\"$proxy_domain\""
  fi

  echo "$content" >"$dir/.xcind.sh"
}

__xcind-workspace-init() {
  local dir="."
  local _flag_proxy_domain=""
  local _flag_name=""

  # Parse arguments: optional positional DIR followed by flags
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --proxy-domain)
      _flag_proxy_domain="$2"
      shift 2
      ;;
    --name)
      _flag_name="$2"
      shift 2
      ;;
    -*)
      echo "Error: Unknown option for init: $1" >&2
      exit 1
      ;;
    *)
      dir="$1"
      shift
      ;;
    esac
  done

  # Resolve to absolute path
  mkdir -p "$dir"
  dir=$(cd "$dir" && pwd)

  # Check if .xcind.sh exists
  if [[ -f "$dir/.xcind.sh" ]]; then
    if __xcind-is-workspace-dir "$dir"; then
      # Already a workspace — update if flags provided, else report
      if [[ -n "$_flag_name" || -n "$_flag_proxy_domain" ]]; then
        local _existing_ws=""
        local _existing_domain=""
        # Source existing values for merge
        XCIND_WORKSPACE=""
        XCIND_PROXY_DOMAIN=""
        # shellcheck disable=SC1091
        source "$dir/.xcind.sh"
        _existing_ws="${XCIND_WORKSPACE:-}"
        _existing_domain="${XCIND_PROXY_DOMAIN:-}"

        [[ -n "$_flag_name" ]] && _existing_ws="$_flag_name"
        [[ -n "$_flag_proxy_domain" ]] && _existing_domain="$_flag_proxy_domain"

        __xcind-workspace-write-config "$dir" "$_existing_ws" "$_existing_domain"
        echo "Workspace updated at $dir"
      else
        echo "Workspace already initialized at $dir"
      fi
      return 0
    fi

    # .xcind.sh exists but is NOT a workspace — this is an app config
    local parent
    parent=$(dirname "$dir")

    if __xcind-is-workspace-dir "$parent"; then
      echo "You're in app '$(basename "$dir")' inside workspace '$(basename "$parent")' (already initialized at $parent)." >&2
    elif [[ -f "$parent/.xcind.sh" ]]; then
      echo "This directory contains an app configuration. Specify a workspace directory explicitly." >&2
    else
      echo "This directory contains an app configuration." >&2
      echo "To initialize the parent as a workspace, run:" >&2
      echo "    xcind-workspace init $parent" >&2
    fi
    return 1
  fi

  # No .xcind.sh exists — create workspace
  __xcind-workspace-write-config "$dir" "$_flag_name" "$_flag_proxy_domain"
  echo "Workspace initialized at $dir"
}

# --------------------------------------------------------------------------
# Status
# --------------------------------------------------------------------------

__xcind-workspace-find-root() {
  local dir="${1:-$PWD}"

  # Resolve to absolute
  if [[ -d "$dir" ]]; then
    dir=$(cd "$dir" && pwd)
  else
    echo "Error: Directory not found: $dir" >&2
    return 1
  fi

  # Direct check: is this a workspace root?
  if __xcind-is-workspace-dir "$dir"; then
    echo "$dir"
    return 0
  fi

  # Try to discover workspace from current location (walk up)
  local current="$dir"
  while true; do
    local parent
    parent=$(dirname "$current")

    if [[ "$parent" == "/" || "$parent" == "$current" ]]; then
      break
    fi

    if __xcind-is-workspace-dir "$parent"; then
      echo "$parent"
      return 0
    fi

    current="$parent"
  done

  echo "Error: Not inside a workspace. Specify a workspace directory or run from within a workspace." >&2
  return 1
}

__xcind-workspace-status() {
  local dir=""
  local json_mode=false

  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --json)
      json_mode=true
      shift
      ;;
    -*)
      echo "Error: Unknown option for status: $1" >&2
      exit 1
      ;;
    *)
      dir="$1"
      shift
      ;;
    esac
  done

  # Discover workspace root
  local ws_root
  if [[ -n "$dir" ]]; then
    ws_root=$(__xcind-workspace-find-root "$dir") || exit 1
  else
    ws_root=$(__xcind-workspace-find-root "$PWD") || exit 1
  fi

  # Source workspace config
  XCIND_WORKSPACE=""
  XCIND_PROXY_DOMAIN=""
  # shellcheck disable=SC1091
  source "$ws_root/.xcind.sh"
  local ws_name="${XCIND_WORKSPACE:-$(basename "$ws_root")}"
  local ws_domain="${XCIND_PROXY_DOMAIN:-localhost}"

  # Source global proxy config if available
  local proxy_config="${XCIND_PROXY_CONFIG_DIR}/config.sh"
  if [[ -f "$proxy_config" ]]; then
    # shellcheck disable=SC1090
    source "$proxy_config"
    ws_domain="${XCIND_PROXY_DOMAIN:-$ws_domain}"
  fi

  # Find apps (subdirectories with .xcind.sh that are NOT workspaces).
  #
  # The glob intentionally skips hidden directories ("$ws_root"/.*/): a
  # workspace root typically contains .git, .cache, and other dot-dirs
  # that should never be treated as apps. Users who want an app directory
  # whose name starts with "." must rename or move it.
  local -a app_dirs=()
  local -a app_names=()
  local subdir
  for subdir in "$ws_root"/*/; do
    [[ ! -d "$subdir" ]] && continue
    local app_candidate="${subdir%/}"
    [[ ! -f "$app_candidate/.xcind.sh" ]] && continue

    if ! __xcind-is-workspace-dir "$app_candidate"; then
      app_dirs+=("$app_candidate")
      app_names+=("$(basename "$app_candidate")")
    fi
  done

  # Check workspace network
  local network_name="${ws_name}-internal"
  local network_exists=false
  if command -v docker &>/dev/null; then
    if docker network inspect "$network_name" &>/dev/null 2>&1; then
      network_exists=true
    fi
  fi

  # Check proxy status
  local proxy_running=false
  local proxy_port="${XCIND_PROXY_HTTP_PORT:-80}"
  if command -v docker &>/dev/null; then
    local running_q
    running_q=$(docker ps --filter label=xcind.component=proxy --filter status=running -q 2>/dev/null) || true
    if [[ -n "$running_q" ]]; then
      proxy_running=true
    fi
  fi

  # ----------------------------------------------------------------------
  # Validate dependencies
  # ----------------------------------------------------------------------

  # jq is required for --json output (existing requirement)
  if [[ "$json_mode" == true ]] && ! command -v jq &>/dev/null; then
    echo "Error: jq is required for --json output." >&2
    exit 1
  fi

  # The defined-services count requires both jq (to parse xcind-config JSON
  # for the metadata.workspace check) and yq (to enumerate services from the
  # resolved compose file). When either is missing, fall back to counting
  # created containers — the legacy behavior — instead of failing.
  local use_config_flow=true
  if ! command -v jq &>/dev/null || ! command -v yq &>/dev/null; then
    use_config_flow=false
  fi

  # ----------------------------------------------------------------------
  # Per-app data collection
  # ----------------------------------------------------------------------

  local _xcind_status_tmpdir=""
  if [[ "$use_config_flow" == true ]]; then
    _xcind_status_tmpdir=$(mktemp -d 2>/dev/null) || _xcind_status_tmpdir=""
    if [[ -z "$_xcind_status_tmpdir" ]]; then
      use_config_flow=false
    else
      # Guarantee cleanup even if set -e aborts the script before the
      # explicit rm at the end of the function runs. The script invokes
      # __xcind-workspace-status at most once, so a script-level EXIT
      # trap is safe here.
      # shellcheck disable=SC2064 # expand tmpdir at trap-set time
      trap "rm -rf '$_xcind_status_tmpdir'" EXIT
    fi
  fi

  local -a app_filtered_dirs=()
  local -a app_filtered_names=()
  local -a app_total_counts=()
  local -a app_running_counts=()
  local -a app_defined_str=()
  local -a app_svc_containers_str=()
  local -a app_svc_statuses_str=()
  local -a app_urls_str=()
  local -a app_errors=()

  local _i=0
  while [[ $_i -lt ${#app_dirs[@]} ]]; do
    local app_dir="${app_dirs[$_i]}"
    local app_name="${app_names[$_i]}"
    local _err_msg=""
    local _total=0
    local _defined=""

    # Try the config-driven flow: ask xcind-config for the app's resolved
    # metadata and compose file in a single invocation. This lets us verify
    # the app actually belongs to this workspace (via metadata.workspace) and
    # enumerate the services that are *defined* by the compose project, not
    # just the ones that happen to have created containers right now.
    if [[ "$use_config_flow" == true ]]; then
      local _tmp_compose="$_xcind_status_tmpdir/${app_name}.yaml"
      local _err_file="$_xcind_status_tmpdir/${app_name}.err"
      local _xcind_json=""
      local _xcind_ok=false

      if _xcind_json=$(
        unset XCIND_APP XCIND_WORKSPACE XCIND_WORKSPACE_ROOT XCIND_WORKSPACELESS XCIND_IS_WORKSPACE
        PATH="$XCIND_ROOT/bin:$PATH" XCIND_APP_ROOT="$app_dir" \
          "$XCIND_ROOT/bin/xcind-config" --json \
          --generate-docker-compose-configuration="$_tmp_compose" 2>"$_err_file"
      ); then
        _xcind_ok=true
      fi

      if [[ "$_xcind_ok" == true ]]; then
        local _app_ws _jq_err_file="$_xcind_status_tmpdir/${app_name}.jqerr"
        local _jq_rc=0
        _app_ws=$(printf '%s' "$_xcind_json" | jq -r '.metadata.workspace // ""' 2>"$_jq_err_file") || _jq_rc=$?
        if [[ $_jq_rc -ne 0 ]]; then
          # A real jq failure means xcind-config emitted malformed JSON —
          # surface the error so the user can see it, and fall back to
          # skipping this app (preserving the current "not in workspace"
          # behavior for downstream code).
          local _jq_err
          _jq_err=$(head -n 1 "$_jq_err_file" 2>/dev/null || true)
          [[ -z "$_jq_err" ]] && _jq_err="jq failed with exit code $_jq_rc"
          echo "xcind-workspace: warning: failed to parse metadata for ${app_name}: ${_jq_err}" >&2
          _app_ws=""
        fi

        if [[ "$_app_ws" != "$ws_name" ]]; then
          # Silently skip apps that aren't configured for this workspace.
          _i=$((_i + 1))
          continue
        fi

        if [[ -f "$_tmp_compose" ]]; then
          _defined=$(__xcind-list-services "$_tmp_compose" || true)
          if [[ -n "$_defined" ]]; then
            _total=$(printf '%s\n' "$_defined" | wc -l | tr -d ' ')
          fi
        fi
      else
        _err_msg=$(head -n 1 "$_err_file" 2>/dev/null || true)
        [[ -z "$_err_msg" ]] && _err_msg="xcind-config failed"
      fi
    fi

    # Query containers for this app+workspace
    local _svc_containers=""
    local _svc_statuses=""
    local _running=0
    local _legacy_total=0

    if command -v docker &>/dev/null; then
      local container_lines
      container_lines=$(docker ps -a \
        --filter "label=xcind.app.name=$app_name" \
        --filter "label=xcind.workspace.name=$ws_name" \
        --format '{{.Names}}\t{{.Status}}' 2>/dev/null) || true

      if [[ -n "$container_lines" ]]; then
        local cname cstatus _state
        while IFS=$'\t' read -r cname cstatus; do
          [[ -z "$cname" ]] && continue
          _legacy_total=$((_legacy_total + 1))
          _state="unknown"
          if [[ "$cstatus" == Up* ]]; then
            _state="running"
            _running=$((_running + 1))
          elif [[ "$cstatus" == Exited* ]]; then
            _state="exited"
          elif [[ "$cstatus" == Paused* ]]; then
            _state="paused"
          elif [[ "$cstatus" == Restarting* ]]; then
            _state="restarting"
          fi
          [[ -n "$_svc_containers" ]] && _svc_containers+=$'\n'
          _svc_containers+="$cname"
          [[ -n "$_svc_statuses" ]] && _svc_statuses+=$'\n'
          _svc_statuses+="$_state"
        done <<<"$container_lines"
      fi
    fi

    # When the new flow isn't running, use today's denominator
    # (count of created containers).
    if [[ "$use_config_flow" != true ]]; then
      _total=$_legacy_total
    fi

    # Collect proxy URLs for this app from container labels
    local _urls=""
    if command -v docker &>/dev/null; then
      local cids
      cids=$(docker ps -q \
        --filter "label=xcind.app.name=$app_name" \
        --filter "label=xcind.workspace.name=$ws_name" 2>/dev/null) || true

      if [[ -n "$cids" ]]; then
        local cid host_labels host_label
        while IFS= read -r cid; do
          [[ -z "$cid" ]] && continue
          # shellcheck disable=SC2016
          host_labels=$(docker inspect --format \
            '{{range $k, $v := .Config.Labels}}{{if hasPrefix "xcind.export." $k}}{{if hasSuffix ".host" $k}}{{$v}}{{"\n"}}{{end}}{{end}}{{end}}' \
            "$cid" 2>/dev/null) || true
          while IFS= read -r host_label; do
            [[ -z "$host_label" ]] && continue
            [[ -n "$_urls" ]] && _urls+=$'\n'
            _urls+="$host_label"
          done <<<"$host_labels"
        done <<<"$cids"
      fi
    fi

    app_filtered_dirs+=("$app_dir")
    app_filtered_names+=("$app_name")
    app_total_counts+=("$_total")
    app_running_counts+=("$_running")
    app_defined_str+=("$_defined")
    app_svc_containers_str+=("$_svc_containers")
    app_svc_statuses_str+=("$_svc_statuses")
    app_urls_str+=("$_urls")
    app_errors+=("$_err_msg")

    _i=$((_i + 1))
  done

  # ----------------------------------------------------------------------
  # Output
  # ----------------------------------------------------------------------

  if [[ "$json_mode" == true ]]; then
    local -a app_json_parts=()
    local _j=0
    while [[ $_j -lt ${#app_filtered_dirs[@]} ]]; do
      # Build services map: { container_name: { status: "..." }, ... }
      local services_json="{}"
      local svc_lines="${app_svc_containers_str[$_j]}"
      local stat_lines="${app_svc_statuses_str[$_j]}"
      if [[ -n "$svc_lines" ]]; then
        local svc_arr stat_arr
        svc_arr=$(printf '%s' "$svc_lines" | jq -R . | jq -s .)
        stat_arr=$(printf '%s' "$stat_lines" | jq -R . | jq -s .)
        services_json=$(jq -n --argjson n "$svc_arr" --argjson s "$stat_arr" \
          '[range(0; $n | length)] | map({key: $n[.], value: {status: $s[.]}}) | from_entries')
      fi

      local defined_json="[]"
      local def_lines="${app_defined_str[$_j]}"
      if [[ -n "$def_lines" ]]; then
        defined_json=$(printf '%s' "$def_lines" | jq -R . | jq -s .)
      fi

      local urls_json="[]"
      local url_lines="${app_urls_str[$_j]}"
      if [[ -n "$url_lines" ]]; then
        urls_json=$(printf '%s' "$url_lines" | jq -R . | jq -s .)
      fi

      app_json_parts+=("$(jq -n \
        --arg name "${app_filtered_names[$_j]}" \
        --arg path "${app_filtered_dirs[$_j]}" \
        --argjson services "$services_json" \
        --argjson defined_services "$defined_json" \
        --argjson total "${app_total_counts[$_j]}" \
        --argjson running "${app_running_counts[$_j]}" \
        --argjson urls "$urls_json" \
        --arg error "${app_errors[$_j]}" \
        '{
          name: $name,
          path: $path,
          services: $services,
          defined_services: $defined_services,
          total: $total,
          running: $running,
          urls: $urls
        } + (if $error == "" then {} else {error: $error} end)')")

      _j=$((_j + 1))
    done

    local apps_json="[]"
    if [[ ${#app_json_parts[@]} -gt 0 ]]; then
      apps_json=$(printf '%s\n' "${app_json_parts[@]}" | jq -s .)
    fi

    jq -n \
      --arg workspace "$ws_name" \
      --arg root "$ws_root" \
      --arg domain "$ws_domain" \
      --argjson apps "$apps_json" \
      --arg network_name "$network_name" \
      --argjson network_exists "$network_exists" \
      --argjson proxy_running "$proxy_running" \
      --arg proxy_port "$proxy_port" \
      --arg proxy_domain "$ws_domain" \
      '{
        workspace: $workspace,
        root: $root,
        domain: $domain,
        apps: $apps,
        network: {name: $network_name, exists: $network_exists},
        proxy: {running: $proxy_running, port: $proxy_port, domain: $proxy_domain}
      }'
  else
    echo "Workspace: $ws_name"
    echo "Root:      $ws_root"
    echo "Domain:    $ws_domain"
    echo ""
    echo "Apps:"

    if [[ ${#app_filtered_dirs[@]} -eq 0 ]]; then
      echo "  (none)"
    else
      local _k=0
      while [[ $_k -lt ${#app_filtered_dirs[@]} ]]; do
        local _app_name="${app_filtered_names[$_k]}"
        local _total_count="${app_total_counts[$_k]}"
        local _running_count="${app_running_counts[$_k]}"
        local _err="${app_errors[$_k]}"

        local indicator="○"
        if [[ $_running_count -gt 0 ]]; then
          indicator="●"
        fi

        local status_text
        if [[ -n "$_err" ]]; then
          status_text="error: $_err"
        elif [[ $_total_count -gt 0 ]]; then
          status_text="$_running_count/$_total_count services running"
        else
          status_text="stopped"
        fi

        printf "  %-14s %s %s\n" "${_app_name}/" "$indicator" "$status_text"
        _k=$((_k + 1))
      done
    fi

    echo ""
    if [[ "$network_exists" == true ]]; then
      echo "Network: $network_name ✓"
    else
      echo "Network: $network_name (not created)"
    fi
    if [[ "$proxy_running" == true ]]; then
      echo "Proxy:   ● running (port $proxy_port)"
    else
      echo "Proxy:   ○ stopped"
    fi
  fi

  # Clean up tempdir
  if [[ -n "$_xcind_status_tmpdir" && -d "$_xcind_status_tmpdir" ]]; then
    rm -rf "$_xcind_status_tmpdir"
  fi
}

# --------------------------------------------------------------------------
# Help
# --------------------------------------------------------------------------

__xcind-workspace-help() {
  echo "Usage: xcind-workspace <subcommand>"
  echo ""
  echo "Subcommands:"
  echo "  init [DIR] [OPTIONS]     Initialize a workspace directory"
  echo "  status [DIR] [OPTIONS]   Show workspace-wide status"
  echo ""
  echo "Init options:"
  echo "  --name NAME              Set XCIND_WORKSPACE explicitly"
  echo "  --proxy-domain DOMAIN    Set XCIND_PROXY_DOMAIN in workspace config"
  echo ""
  echo "Status options:"
  echo "  --json                   Output structured JSON"
  echo ""
  echo "Note: 'status' sources the .xcind.sh file in every subdirectory of"
  echo "the workspace root. Those files may execute arbitrary shell code."
  echo "Only run 'status' inside workspace roots you control."
  echo ""
  echo "Options:"
  echo "  --version, -V  Show version"
  echo "  --help, -h     Show this help"
}

# --------------------------------------------------------------------------
# Dispatch
# --------------------------------------------------------------------------

# Gentle nudge if jq/yq aren't on PATH (silent in scripts and CI). Placed
# after the --version short-circuit and before dispatch so --help still
# prints cleanly.
if [[ ${1:-} != "--help" && ${1:-} != "-h" && ${1:-} != "" ]]; then
  __xcind-maybe-warn-deps
fi

case "${1:-}" in
init)
  shift
  __xcind-workspace-init "$@"
  ;;
status)
  shift
  __xcind-workspace-status "$@"
  ;;
--help | -h)
  __xcind-workspace-help
  exit 0
  ;;
"")
  __xcind-workspace-help
  exit 0
  ;;
*)
  echo "Error: Unknown command: $1" >&2
  echo "Run 'xcind-workspace --help' for usage." >&2
  exit 1
  ;;
esac
