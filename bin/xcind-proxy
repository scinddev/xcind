#!/usr/bin/env bash
# xcind-proxy — Manage shared Traefik proxy infrastructure
#
# Usage:
#   xcind-proxy init      Create proxy infrastructure files
#   xcind-proxy up        Start the shared Traefik proxy
#   xcind-proxy down      Stop the shared Traefik proxy
#   xcind-proxy status [--json]  Show proxy state
#   xcind-proxy logs      Show Traefik proxy logs

set -euo pipefail

# Resolve XCIND_ROOT by following symlinks to the real install directory
# (npm, nix profile, and manual symlinks all route through here). macOS
# lacks `readlink -f`, so the resolver is a manual loop.
# Keep in sync with the equivalent stub in the other bin/ scripts.
__xcind_src="${BASH_SOURCE[0]}"
while [ -L "$__xcind_src" ]; do
  __xcind_src_dir=$(cd "$(dirname "$__xcind_src")" && pwd)
  __xcind_src=$(readlink "$__xcind_src")
  [[ $__xcind_src != /* ]] && __xcind_src="$__xcind_src_dir/$__xcind_src"
done
XCIND_ROOT="$(cd "$(dirname "$__xcind_src")/.." && pwd)"
unset __xcind_src __xcind_src_dir
# shellcheck disable=SC1091
source "$XCIND_ROOT/lib/xcind/xcind-bootstrap.bash"

if [[ ${1:-} == "--version" ]] || [[ ${1:-} == "-V" ]]; then
  echo "xcind-proxy ${XCIND_VERSION}"
  exit 0
fi

# --------------------------------------------------------------------------
# Subcommands (delegate to shared functions in xcind-proxy-lib.bash)
# --------------------------------------------------------------------------

__xcind-proxy-init() {
  # Parse init-specific flags
  local _flag_proxy_domain=""
  local _flag_http_port=""
  local _flag_image=""
  local _flag_dashboard=""
  local _flag_dashboard_port=""
  local _flag_tls_mode=""
  local _flag_https_port=""
  local _flag_tls_cert_file=""
  local _flag_tls_key_file=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --proxy-domain)
      _flag_proxy_domain="$2"
      shift 2
      ;;
    --http-port)
      _flag_http_port="$2"
      shift 2
      ;;
    --image)
      _flag_image="$2"
      shift 2
      ;;
    --dashboard)
      _flag_dashboard="$2"
      shift 2
      ;;
    --dashboard-port)
      _flag_dashboard_port="$2"
      shift 2
      ;;
    --tls-mode)
      _flag_tls_mode="$2"
      shift 2
      ;;
    --https-port)
      _flag_https_port="$2"
      shift 2
      ;;
    --tls-cert-file)
      _flag_tls_cert_file="$2"
      shift 2
      ;;
    --tls-key-file)
      _flag_tls_key_file="$2"
      shift 2
      ;;
    *)
      echo "Error: Unknown option for init: $1" >&2
      exit 1
      ;;
    esac
  done

  # Validate --tls-mode value early — writing an invalid value into config.sh
  # would produce confusing downstream errors.
  if [[ -n $_flag_tls_mode ]]; then
    case "$_flag_tls_mode" in
    auto | custom | disabled) ;;
    *)
      echo "Error: --tls-mode must be 'auto', 'custom', or 'disabled' (got: $_flag_tls_mode)" >&2
      exit 1
      ;;
    esac
  fi

  mkdir -p "$XCIND_PROXY_CONFIG_DIR" "$XCIND_PROXY_STATE_DIR"

  # Source existing config if present (provides current values as defaults)
  if [[ -f "$XCIND_PROXY_CONFIG_DIR/config.sh" ]]; then
    # shellcheck disable=SC1091
    source "$XCIND_PROXY_CONFIG_DIR/config.sh"
  fi

  # Apply CLI flag overrides (variables consumed by __xcind-proxy-write-config)
  # shellcheck disable=SC2034
  [[ -n "$_flag_proxy_domain" ]] && XCIND_PROXY_DOMAIN="$_flag_proxy_domain"
  # shellcheck disable=SC2034
  [[ -n "$_flag_http_port" ]] && XCIND_PROXY_HTTP_PORT="$_flag_http_port"
  # shellcheck disable=SC2034
  [[ -n "$_flag_image" ]] && XCIND_PROXY_IMAGE="$_flag_image"
  # shellcheck disable=SC2034
  [[ -n "$_flag_dashboard" ]] && XCIND_PROXY_DASHBOARD="$_flag_dashboard"
  # shellcheck disable=SC2034
  [[ -n "$_flag_dashboard_port" ]] && XCIND_PROXY_DASHBOARD_PORT="$_flag_dashboard_port"
  # shellcheck disable=SC2034
  [[ -n "$_flag_tls_mode" ]] && XCIND_PROXY_TLS_MODE="$_flag_tls_mode"
  # shellcheck disable=SC2034
  [[ -n "$_flag_https_port" ]] && XCIND_PROXY_HTTPS_PORT="$_flag_https_port"
  # shellcheck disable=SC2034
  [[ -n "$_flag_tls_cert_file" ]] && XCIND_PROXY_TLS_CERT_FILE="$_flag_tls_cert_file"
  # shellcheck disable=SC2034
  [[ -n "$_flag_tls_key_file" ]] && XCIND_PROXY_TLS_KEY_FILE="$_flag_tls_key_file"

  # Write config (always — merges existing + overrides)
  __xcind-proxy-write-config

  # Run full init (sources config, generates compose/traefik, creates network)
  __xcind-proxy-ensure-init

  # Prune stale assigned-port entries so the next run starts from a clean slate
  __xcind-with-assigned-lock __xcind-assigned-prune >/dev/null

  echo "Proxy config at $XCIND_PROXY_CONFIG_DIR"
  echo "Generated files at $XCIND_PROXY_STATE_DIR"
}

__xcind-proxy-up() {
  local force=false
  if [[ ${1:-} == "--force" ]]; then
    force=true
  fi

  if [[ $force == true ]]; then
    # Tear down existing containers so the network can be recreated
    docker compose -f "$XCIND_PROXY_COMPOSE" down 2>/dev/null || true
    docker network rm "$XCIND_PROXY_NETWORK" 2>/dev/null || true
  fi

  # Always regenerate files from current config.sh
  __xcind-proxy-ensure-init

  # Prune stale assigned-port entries before bringing the stack up
  __xcind-with-assigned-lock __xcind-assigned-prune >/dev/null

  if [ "$force" = true ]; then
    docker compose -f "$XCIND_PROXY_COMPOSE" up -d || return $?
  else
    # Start if not already running
    XCIND_PROXY_AUTO_START=1 __xcind-proxy-ensure-running
  fi
}

__xcind-proxy-down() {
  local compose_file="$XCIND_PROXY_COMPOSE"

  # Fallback: check old location for pre-migration installs
  if [ ! -f "$compose_file" ] && [ -f "$XCIND_PROXY_CONFIG_DIR/docker-compose.yaml" ]; then
    compose_file="$XCIND_PROXY_CONFIG_DIR/docker-compose.yaml"
  fi

  if [ ! -f "$compose_file" ]; then
    echo "Proxy not initialized. Run 'xcind-proxy init' to set up proxy infrastructure." >&2
    exit 1
  fi

  docker compose -f "$compose_file" down
}

__xcind-proxy-status() {
  local json_mode=false
  if [[ ${1:-} == "--json" ]]; then
    json_mode=true
  fi

  # jq is required for --json output (the hand-rolled printf template used
  # to be tolerant of missing jq, but since the output is now built with
  # `jq -n`, fail loudly instead of producing broken JSON).
  if [[ "$json_mode" == true ]] && ! command -v jq &>/dev/null; then
    echo "Error: jq is required for --json output." >&2
    exit 1
  fi

  # Prune stale assigned-port entries so the status display never carries
  # orphaned rows from deleted apps.
  __xcind-with-assigned-lock __xcind-assigned-prune >/dev/null

  # Not initialized
  if [ ! -f "$XCIND_PROXY_COMPOSE" ]; then
    if [ "$json_mode" = true ]; then
      jq -cn '{initialized: false, status: "not_initialized", assigned_ports: []}'
    else
      echo "Status: not initialized"
      echo "Run 'xcind-proxy init' to set up proxy infrastructure."
      __xcind-proxy-status-assigned-text
    fi
    return 0
  fi

  # Source config for display. The outer check at line 158 guarantees the
  # compose file exists, but config.sh could still be missing (e.g., after a
  # manual delete or a partial migration) — fall through with defaults in
  # that case so status still prints something useful.
  if [ -f "$XCIND_PROXY_CONFIG_DIR/config.sh" ]; then
    # shellcheck disable=SC1091
    source "$XCIND_PROXY_CONFIG_DIR/config.sh"
  fi

  # Check if running
  local running_raw
  running_raw=$(docker compose -f "$XCIND_PROXY_COMPOSE" ps --format json 2>/dev/null | head -1) || true
  local running_status="stopped"
  if [ -n "$running_raw" ]; then
    running_status="running"
  fi

  # Check config staleness
  local config_status="current"
  if [[ -f "$XCIND_PROXY_CONFIG_DIR/config.sh" && -f $XCIND_PROXY_COMPOSE ]] &&
    [[ "$XCIND_PROXY_CONFIG_DIR/config.sh" -nt $XCIND_PROXY_COMPOSE ]]; then
    config_status="stale"
  fi

  local image="${XCIND_PROXY_IMAGE:-traefik:v3}"
  local http_port="${XCIND_PROXY_HTTP_PORT:-80}"
  local tls_mode="${XCIND_PROXY_TLS_MODE:-auto}"
  local https_port="${XCIND_PROXY_HTTPS_PORT:-443}"
  local tls_enabled=true
  [[ $tls_mode == "disabled" ]] && tls_enabled=false
  local dashboard_enabled=false
  local dashboard_url=""
  if [ "${XCIND_PROXY_DASHBOARD:-false}" = "true" ]; then
    dashboard_enabled=true
    dashboard_url="http://localhost:${XCIND_PROXY_DASHBOARD_PORT:-8080}"
  fi

  local network_name="$XCIND_PROXY_NETWORK"
  local network_exists=false
  if docker network inspect "$XCIND_PROXY_NETWORK" &>/dev/null; then
    network_exists=true
  fi

  # Output
  if [ "$json_mode" = true ]; then
    local assigned_json
    assigned_json=$(__xcind-proxy-status-assigned-json)
    jq -cn \
      --arg status "$running_status" \
      --arg config "$config_status" \
      --arg image "$image" \
      --argjson http_port "$http_port" \
      --arg tls_mode "$tls_mode" \
      --argjson tls_enabled "$tls_enabled" \
      --argjson https_port "$https_port" \
      --argjson dashboard_enabled "$dashboard_enabled" \
      --arg dashboard_url "$dashboard_url" \
      --arg network_name "$network_name" \
      --argjson network_exists "$network_exists" \
      --argjson assigned_ports "$assigned_json" \
      '{
        initialized: true,
        status: $status,
        config: $config,
        image: $image,
        http_port: $http_port,
        tls_mode: $tls_mode,
        tls_enabled: $tls_enabled,
        https_port: $https_port,
        dashboard_enabled: $dashboard_enabled,
        dashboard_url: $dashboard_url,
        network_name: $network_name,
        network_exists: $network_exists,
        assigned_ports: $assigned_ports
      }'
  else
    echo "Status: $running_status"
    if [ "$config_status" = "stale" ]; then
      echo "Config: stale (run 'xcind-proxy up' to regenerate)"
    else
      echo "Config: current"
    fi
    echo "Image: $image"
    echo "HTTP port: $http_port"
    echo "TLS mode: $tls_mode"
    if [ "$tls_enabled" = true ]; then
      echo "HTTPS port: $https_port"
    fi
    if [ "$dashboard_enabled" = true ]; then
      echo "Dashboard: $dashboard_url"
    fi
    if [ "$network_exists" = true ]; then
      echo "Network: $network_name (exists)"
    else
      echo "Network: $network_name (missing)"
    fi
    __xcind-proxy-status-assigned-text
  fi
}

# Render the assigned-ports section of `xcind-proxy status` as plain text.
# Reads the state file directly via __xcind-assigned-iter — callers already
# hold (or have released) the assigned-ports lock; this is a read-only
# snapshot.
__xcind-proxy-status-assigned-text() {
  __xcind_proxy_status_text_any=0
  __xcind-assigned-iter __xcind-proxy-status-assigned-text-row
  unset __xcind_proxy_status_text_any
}

__xcind-proxy-status-assigned-text-row() {
  local L_port="$1" L_workspace="$2" L_application="$3" L_service="$4"
  local L_cport="$5" L_path="$6"
  if [ "$__xcind_proxy_status_text_any" -eq 0 ]; then
    echo ""
    echo "Assigned ports:"
    __xcind_proxy_status_text_any=1
  fi
  local prefix
  if [[ -n $L_workspace ]]; then
    prefix="$L_workspace/$L_application/$L_service"
  else
    prefix="$L_application/$L_service"
  fi
  printf '  %s  %s  → container port %s  (%s)\n' \
    "$L_port" "$prefix" "$L_cport" "$L_path"
}

# Render the assigned-ports section as a JSON array.
__xcind-proxy-status-assigned-json() {
  if ! command -v jq &>/dev/null; then
    echo "[]"
    return 0
  fi
  __xcind_proxy_status_json_result="[]"
  __xcind-assigned-iter __xcind-proxy-status-assigned-json-row
  printf '%s' "$__xcind_proxy_status_json_result"
  unset __xcind_proxy_status_json_result
}

__xcind-proxy-status-assigned-json-row() {
  local L_port="$1" L_workspace="$2" L_application="$3" L_service="$4"
  local L_cport="$5" L_path="$6" L_ts="$7"
  __xcind_proxy_status_json_result=$(printf '%s' "$__xcind_proxy_status_json_result" | jq \
    --argjson port "$L_port" \
    --arg workspace "$L_workspace" \
    --arg application "$L_application" \
    --arg service "$L_service" \
    --argjson cport "$L_cport" \
    --arg path "$L_path" \
    --arg ts "$L_ts" \
    '. + [{host_port: $port, workspace: $workspace, application: $application, service: $service, container_port: $cport, app_path: $path, assigned_at: $ts}]')
}

__xcind-proxy-release() {
  local port="${1:-}"
  if [[ -z $port ]]; then
    echo "Usage: xcind-proxy release <port>" >&2
    exit 1
  fi
  if ! [[ $port =~ ^[0-9]+$ ]]; then
    echo "Error: port must be a positive integer, got: $port" >&2
    exit 1
  fi
  if __xcind-with-assigned-lock __xcind-assigned-remove-port "$port"; then
    echo "Released assigned port $port"
  else
    echo "No assignment found for port $port" >&2
    exit 1
  fi
}

__xcind-proxy-prune() {
  local pruned
  pruned=$(__xcind-with-assigned-lock __xcind-assigned-prune)
  echo "Pruned $pruned stale assigned port entries"
}

__xcind-proxy-logs() {
  if [ ! -f "$XCIND_PROXY_COMPOSE" ]; then
    echo "Proxy not initialized. Run 'xcind-proxy init' to set up proxy infrastructure." >&2
    exit 1
  fi

  docker compose -f "$XCIND_PROXY_COMPOSE" logs "$@"
}

# --------------------------------------------------------------------------
# Help
# --------------------------------------------------------------------------

__xcind-proxy-help() {
  echo "Usage: xcind-proxy <subcommand>"
  echo ""
  echo "Subcommands:"
  echo "  init [OPTIONS]     Create proxy infrastructure files"
  echo "  up [--force]       Start the shared Traefik proxy (--force recreates network)"
  echo "  down               Stop the shared Traefik proxy"
  echo "  status [--json]    Show proxy state (running/stopped, image, port, network, assigned ports)"
  echo "  logs [OPTS]        Show Traefik proxy logs (supports docker compose logs flags)"
  echo "  release PORT       Release an assigned port from the state file"
  echo "  prune              Remove assigned-port entries whose app path no longer exists"
  echo ""
  echo "Init options:"
  echo "  --proxy-domain DOMAIN     Set domain suffix (default: localhost)"
  echo "  --http-port PORT          Set HTTP port (default: 80)"
  echo "  --image IMAGE             Set Traefik Docker image (default: traefik:v3)"
  echo "  --dashboard BOOL          Enable Traefik dashboard (default: false)"
  echo "  --dashboard-port PORT     Set dashboard port (default: 8080)"
  echo "  --tls-mode MODE           TLS mode: auto, custom, disabled (default: auto)"
  echo "  --https-port PORT         Set HTTPS port (default: 443)"
  echo "  --tls-cert-file PATH      Custom cert file (only used when --tls-mode custom)"
  echo "  --tls-key-file PATH       Custom key file (only used when --tls-mode custom)"
  echo ""
  echo "Options:"
  echo "  --version, -V  Show version"
  echo "  --help, -h     Show this help"
}

# --------------------------------------------------------------------------
# Dispatch
# --------------------------------------------------------------------------

# Gentle nudge if jq/yq aren't on PATH (silent in scripts and CI). Placed
# after the --version short-circuit and before dispatch so --help still
# prints cleanly.
if [[ ${1:-} != "--help" && ${1:-} != "-h" ]]; then
  __xcind-maybe-warn-deps
fi

case "${1:-}" in
init)
  shift
  __xcind-proxy-init "$@"
  ;;
up) __xcind-proxy-up "${2:-}" ;;
down) __xcind-proxy-down ;;
status)
  shift
  __xcind-proxy-status "$@"
  ;;
logs)
  shift
  __xcind-proxy-logs "$@"
  ;;
release)
  shift
  __xcind-proxy-release "${1:-}"
  ;;
prune)
  __xcind-proxy-prune
  ;;
--help | -h)
  __xcind-proxy-help
  exit 0
  ;;
"")
  __xcind-proxy-help
  exit 0
  ;;
*)
  echo "Error: Unknown subcommand '$1'. Run 'xcind-proxy --help' for usage." >&2
  exit 1
  ;;
esac
