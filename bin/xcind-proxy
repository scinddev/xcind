#!/usr/bin/env bash
# xcind-proxy — Manage shared Traefik proxy infrastructure
#
# Usage:
#   xcind-proxy init      Create proxy infrastructure files
#   xcind-proxy up        Start the shared Traefik proxy
#   xcind-proxy down      Stop the shared Traefik proxy
#   xcind-proxy status [--json]  Show proxy state
#   xcind-proxy logs      Show Traefik proxy logs

set -euo pipefail

# Locate xcind-bootstrap.bash by following symlinks of this script
# (npm, nix profile, and manual symlinks all route through here).
# Keep in sync with the equivalent stub in the other bin/ scripts.
__xcind_boot="${BASH_SOURCE[0]}"
while [ -L "$__xcind_boot" ]; do
  __xcind_boot_dir=$(cd "$(dirname "$__xcind_boot")" && pwd)
  __xcind_boot=$(readlink "$__xcind_boot")
  [[ $__xcind_boot != /* ]] && __xcind_boot="$__xcind_boot_dir/$__xcind_boot"
done
# shellcheck disable=SC1091
source "$(cd "$(dirname "$__xcind_boot")/.." && pwd)/lib/xcind/xcind-bootstrap.bash"
unset __xcind_boot __xcind_boot_dir

if [[ ${1:-} == "--version" ]] || [[ ${1:-} == "-V" ]]; then
  echo "xcind-proxy ${XCIND_VERSION}"
  exit 0
fi

# --------------------------------------------------------------------------
# Subcommands (delegate to shared functions in xcind-proxy-lib.bash)
# --------------------------------------------------------------------------

__xcind-proxy-init() {
  # Parse init-specific flags
  local _flag_proxy_domain=""
  local _flag_http_port=""
  local _flag_image=""
  local _flag_dashboard=""
  local _flag_dashboard_port=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --proxy-domain)
      _flag_proxy_domain="$2"
      shift 2
      ;;
    --http-port)
      _flag_http_port="$2"
      shift 2
      ;;
    --image)
      _flag_image="$2"
      shift 2
      ;;
    --dashboard)
      _flag_dashboard="$2"
      shift 2
      ;;
    --dashboard-port)
      _flag_dashboard_port="$2"
      shift 2
      ;;
    *)
      echo "Error: Unknown option for init: $1" >&2
      exit 1
      ;;
    esac
  done

  mkdir -p "$XCIND_PROXY_CONFIG_DIR" "$XCIND_PROXY_STATE_DIR"

  # Source existing config if present (provides current values as defaults)
  if [[ -f "$XCIND_PROXY_CONFIG_DIR/config.sh" ]]; then
    # shellcheck disable=SC1091
    source "$XCIND_PROXY_CONFIG_DIR/config.sh"
  fi

  # Apply CLI flag overrides (variables consumed by __xcind-proxy-write-config)
  # shellcheck disable=SC2034
  [[ -n "$_flag_proxy_domain" ]] && XCIND_PROXY_DOMAIN="$_flag_proxy_domain"
  # shellcheck disable=SC2034
  [[ -n "$_flag_http_port" ]] && XCIND_PROXY_HTTP_PORT="$_flag_http_port"
  # shellcheck disable=SC2034
  [[ -n "$_flag_image" ]] && XCIND_PROXY_IMAGE="$_flag_image"
  # shellcheck disable=SC2034
  [[ -n "$_flag_dashboard" ]] && XCIND_PROXY_DASHBOARD="$_flag_dashboard"
  # shellcheck disable=SC2034
  [[ -n "$_flag_dashboard_port" ]] && XCIND_PROXY_DASHBOARD_PORT="$_flag_dashboard_port"

  # Write config (always — merges existing + overrides)
  __xcind-proxy-write-config

  # Run full init (sources config, generates compose/traefik, creates network)
  __xcind-proxy-ensure-init

  echo "Proxy config at $XCIND_PROXY_CONFIG_DIR"
  echo "Generated files at $XCIND_PROXY_STATE_DIR"
}

__xcind-proxy-up() {
  local force=false
  if [[ ${1:-} == "--force" ]]; then
    force=true
  fi

  if [[ $force == true ]]; then
    # Tear down existing containers so the network can be recreated
    docker compose -f "$XCIND_PROXY_COMPOSE" down 2>/dev/null || true
    docker network rm "$XCIND_PROXY_NETWORK" 2>/dev/null || true
  fi

  # Always regenerate files from current config.sh
  __xcind-proxy-ensure-init

  if [ "$force" = true ]; then
    docker compose -f "$XCIND_PROXY_COMPOSE" up -d || return $?
  else
    # Start if not already running
    XCIND_PROXY_AUTO_START=1 __xcind-proxy-ensure-running
  fi
}

__xcind-proxy-down() {
  local compose_file="$XCIND_PROXY_COMPOSE"

  # Fallback: check old location for pre-migration installs
  if [ ! -f "$compose_file" ] && [ -f "$XCIND_PROXY_CONFIG_DIR/docker-compose.yaml" ]; then
    compose_file="$XCIND_PROXY_CONFIG_DIR/docker-compose.yaml"
  fi

  if [ ! -f "$compose_file" ]; then
    echo "Proxy not initialized. Run 'xcind-proxy init' to set up proxy infrastructure." >&2
    exit 1
  fi

  docker compose -f "$compose_file" down
}

__xcind-proxy-status() {
  local json_mode=false
  if [[ ${1:-} == "--json" ]]; then
    json_mode=true
  fi

  # Not initialized
  if [ ! -f "$XCIND_PROXY_COMPOSE" ]; then
    if [ "$json_mode" = true ]; then
      printf '{"initialized":false,"status":"not_initialized"}\n'
    else
      echo "Status: not initialized"
      echo "Run 'xcind-proxy init' to set up proxy infrastructure."
    fi
    return 0
  fi

  # Source config for display
  # shellcheck disable=SC1091
  source "$XCIND_PROXY_CONFIG_DIR/config.sh"

  # Check if running
  local running_raw
  running_raw=$(docker compose -f "$XCIND_PROXY_COMPOSE" ps --format json 2>/dev/null | head -1) || true
  local running_status="stopped"
  if [ -n "$running_raw" ]; then
    running_status="running"
  fi

  # Check config staleness
  local config_status="current"
  if [[ -f "$XCIND_PROXY_CONFIG_DIR/config.sh" && -f $XCIND_PROXY_COMPOSE ]] &&
    [[ "$XCIND_PROXY_CONFIG_DIR/config.sh" -nt $XCIND_PROXY_COMPOSE ]]; then
    config_status="stale"
  fi

  local image="${XCIND_PROXY_IMAGE:-traefik:v3}"
  local http_port="${XCIND_PROXY_HTTP_PORT:-80}"
  local dashboard_enabled=false
  local dashboard_url=""
  if [ "${XCIND_PROXY_DASHBOARD:-false}" = "true" ]; then
    dashboard_enabled=true
    dashboard_url="http://localhost:${XCIND_PROXY_DASHBOARD_PORT:-8080}"
  fi

  local network_name="$XCIND_PROXY_NETWORK"
  local network_exists=false
  if docker network inspect "$XCIND_PROXY_NETWORK" &>/dev/null; then
    network_exists=true
  fi

  # Output
  if [ "$json_mode" = true ]; then
    printf '{"initialized":true,"status":"%s","config":"%s","image":"%s","http_port":%s,"dashboard_enabled":%s,"dashboard_url":"%s","network_name":"%s","network_exists":%s}\n' \
      "$running_status" "$config_status" "$image" "$http_port" "$dashboard_enabled" "$dashboard_url" "$network_name" "$network_exists"
  else
    echo "Status: $running_status"
    if [ "$config_status" = "stale" ]; then
      echo "Config: stale (run 'xcind-proxy up' to regenerate)"
    else
      echo "Config: current"
    fi
    echo "Image: $image"
    echo "HTTP port: $http_port"
    if [ "$dashboard_enabled" = true ]; then
      echo "Dashboard: $dashboard_url"
    fi
    if [ "$network_exists" = true ]; then
      echo "Network: $network_name (exists)"
    else
      echo "Network: $network_name (missing)"
    fi
  fi
}

__xcind-proxy-logs() {
  if [ ! -f "$XCIND_PROXY_COMPOSE" ]; then
    echo "Proxy not initialized. Run 'xcind-proxy init' to set up proxy infrastructure." >&2
    exit 1
  fi

  docker compose -f "$XCIND_PROXY_COMPOSE" logs "$@"
}

# --------------------------------------------------------------------------
# Help
# --------------------------------------------------------------------------

__xcind-proxy-help() {
  echo "Usage: xcind-proxy <subcommand>"
  echo ""
  echo "Subcommands:"
  echo "  init [OPTIONS]     Create proxy infrastructure files"
  echo "  up [--force]       Start the shared Traefik proxy (--force recreates network)"
  echo "  down               Stop the shared Traefik proxy"
  echo "  status [--json]    Show proxy state (running/stopped, image, port, network)"
  echo "  logs [OPTS]        Show Traefik proxy logs (supports docker compose logs flags)"
  echo ""
  echo "Init options:"
  echo "  --proxy-domain DOMAIN     Set domain suffix (default: localhost)"
  echo "  --http-port PORT          Set HTTP port (default: 80)"
  echo "  --image IMAGE             Set Traefik Docker image (default: traefik:v3)"
  echo "  --dashboard BOOL          Enable Traefik dashboard (default: false)"
  echo "  --dashboard-port PORT     Set dashboard port (default: 8080)"
  echo ""
  echo "Options:"
  echo "  --version, -V  Show version"
  echo "  --help, -h     Show this help"
}

# --------------------------------------------------------------------------
# Dispatch
# --------------------------------------------------------------------------

# Gentle nudge if jq/yq aren't on PATH (silent in scripts and CI). Placed
# after the --version short-circuit and before dispatch so --help still
# prints cleanly.
if [[ ${1:-} != "--help" && ${1:-} != "-h" ]]; then
  __xcind-maybe-warn-deps
fi

case "${1:-}" in
init)
  shift
  __xcind-proxy-init "$@"
  ;;
up) __xcind-proxy-up "${2:-}" ;;
down) __xcind-proxy-down ;;
status)
  shift
  __xcind-proxy-status "$@"
  ;;
logs)
  shift
  __xcind-proxy-logs "$@"
  ;;
--help | -h)
  __xcind-proxy-help
  exit 0
  ;;
"")
  __xcind-proxy-help
  exit 0
  ;;
*)
  echo "Error: Unknown subcommand '$1'. Run 'xcind-proxy --help' for usage." >&2
  exit 1
  ;;
esac
