#!/usr/bin/env bash
# xcind-compose — Docker Compose wrapper that resolves project config from .xcind.sh
#
# Usage:
#   xcind-compose up -d
#   xcind-compose build
#   xcind-compose exec php bash
#   xcind-compose ps
#
# This script:
#   1. Detects the app root by walking upward to find .xcind.sh
#   2. Sources .xcind.sh to load project-specific config
#   3. Resolves compose files, env files, and override variants
#   4. Passes everything through to `docker compose`
#
# All arguments are forwarded to docker compose after the resolved flags.

set -euo pipefail

# Resolve the real path of this script, following symlinks (macOS lacks readlink -f)
__xcind_resolve_link() {
  local target="$1"
  while [ -L "$target" ]; do
    local dir
    dir=$(cd "$(dirname "$target")" && pwd)
    target=$(readlink "$target")
    [[ $target != /* ]] && target="$dir/$target"
  done
  echo "$(cd "$(dirname "$target")" && pwd)/$(basename "$target")"
}

XCIND_ROOT="$(cd "$(dirname "$(__xcind_resolve_link "${BASH_SOURCE[0]}")")" && cd .. && pwd)"

# Source the shared library
# shellcheck disable=SC1091
source "$XCIND_ROOT/lib/xcind/xcind-lib.bash"

if [[ ${1:-} == "--xcind-version" ]]; then
  echo "xcind-compose ${XCIND_VERSION}"
  exit 0
fi

# --- Main ---

# Detect app root
app_root=$(__xcind-app-root) || exit 1

# Load project config
__xcind-load-config "$app_root" || exit 1

# Build compose options
__xcind-build-compose-opts "$app_root"

# Execute docker compose with resolved options + passthrough args
exec docker compose "${XCIND_DOCKER_COMPOSE_OPTS[@]}" "$@"
