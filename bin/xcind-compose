#!/usr/bin/env bash
# xcind-compose — Docker Compose wrapper that resolves application config from .xcind.sh
#
# Usage:
#   xcind-compose up -d
#   xcind-compose build
#   xcind-compose exec php bash
#   xcind-compose ps
#
# This script:
#   1. Detects the app root by walking upward to find .xcind.sh
#   2. Sources .xcind.sh to load application-specific config
#   3. Resolves compose files, env files, and override variants
#   4. Passes everything through to `docker compose`
#
# All arguments are forwarded to docker compose after the resolved flags.

set -euo pipefail

# Resolve the real path of this script, following symlinks (macOS lacks readlink -f)
__xcind_resolve_link() {
  local target="$1"
  while [ -L "$target" ]; do
    local dir
    dir=$(cd "$(dirname "$target")" && pwd)
    target=$(readlink "$target")
    [[ $target != /* ]] && target="$dir/$target"
  done
  echo "$(cd "$(dirname "$target")" && pwd)/$(basename "$target")"
}

XCIND_ROOT="$(cd "$(dirname "$(__xcind_resolve_link "${BASH_SOURCE[0]}")")" && cd .. && pwd)"

# Source the shared library
# shellcheck disable=SC1091
source "$XCIND_ROOT/lib/xcind/xcind-lib.bash"

if [[ ${1:-} == "--version" ]] || [[ ${1:-} == "-V" ]] || [[ ${1:-} == "--xcind-version" ]]; then
  echo "xcind-compose ${XCIND_VERSION}"
  exit 0
fi

if [[ ${1:-} == "--help" ]] || [[ ${1:-} == "-h" ]]; then
  cat <<'HELPEOF'
Usage: xcind-compose [OPTIONS] [DOCKER COMPOSE ARGS...]

Docker Compose wrapper that resolves application config from .xcind.sh.

Options:
  --version, -V  Show version
  --help, -h     Show this help

All other arguments are forwarded to docker compose after resolved flags.

Examples:
  xcind-compose up -d
  xcind-compose build
  xcind-compose exec php bash
  xcind-compose ps
HELPEOF
  exit 0
fi

# --- Main ---

# Step 1: Detect app root
# shellcheck disable=SC2119  # intentionally called with no args
app_root=$(__xcind-app-root) || exit 1
export XCIND_APP_ROOT="$app_root"

# Initialize config file tracking
__XCIND_SOURCED_CONFIG_FILES=()

# Step 2: Discover workspace
__xcind-discover-workspace "$app_root"

# Step 3: Source workspace additional configs
if [[ ${XCIND_WORKSPACELESS:-1} == "0" ]] && [[ -n ${XCIND_WORKSPACE_ROOT:-} ]]; then
  __xcind-source-additional-configs "$XCIND_WORKSPACE_ROOT"
fi

# Step 4: Load application config (overrides workspace settings)
__xcind-load-config "$app_root" || exit 1

# Step 5: Source app additional configs
__xcind-source-additional-configs "$app_root"

# Step 6: Late-bind workspace self-declaration
__xcind-late-bind-workspace

# Step 7: Resolve app name
__xcind-resolve-app "$app_root"

# Step 8: Resolve URL templates
__xcind-resolve-url-templates

# Step 9-10: Resolve files and build compose options
__xcind-build-compose-opts "$app_root"

# Steps 11-14: Only run when hooks are registered
if [[ ${#XCIND_HOOKS_GENERATE[@]} -gt 0 ]]; then
  # Step 11: Compute SHA
  XCIND_SHA=$(__xcind-compute-sha "$app_root")

  # Step 12: Export pipeline vars
  export XCIND_SHA
  export XCIND_CACHE_DIR="$app_root/.xcind/cache/$XCIND_SHA"
  export XCIND_GENERATED_DIR="$app_root/.xcind/generated/$XCIND_SHA"
  export XCIND_APP XCIND_WORKSPACE XCIND_WORKSPACE_ROOT XCIND_WORKSPACELESS
  export XCIND_APP_URL_TEMPLATE XCIND_ROUTER_TEMPLATE XCIND_WORKSPACE_SERVICE_TEMPLATE
  export XCIND_APP_APEX_URL_TEMPLATE XCIND_APEX_ROUTER_TEMPLATE

  # Step 13: Populate cache
  __xcind-populate-cache "$app_root"

  # Step 14: Run GENERATE hooks (cache hit = replay, cache miss = execute)
  __xcind-run-hooks "$app_root"
fi

# Step 15: Run EXECUTE hooks (always, not cached)
if [[ ${#XCIND_HOOKS_EXECUTE[@]} -gt 0 ]]; then
  __xcind-run-execute-hooks "$app_root"
fi

# Step 16: Execute docker compose with resolved options + passthrough args
exec docker compose "${XCIND_DOCKER_COMPOSE_OPTS[@]}" "$@"
