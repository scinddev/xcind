#!/usr/bin/env bash
# xcind-compose — Docker Compose wrapper that resolves application config from .xcind.sh
#
# Usage:
#   xcind-compose up -d
#   xcind-compose build
#   xcind-compose exec php bash
#   xcind-compose ps
#
# This script:
#   1. Detects the app root by walking upward to find .xcind.sh
#   2. Sources .xcind.sh to load application-specific config
#   3. Resolves compose files, env files, and override variants
#   4. Passes everything through to `docker compose`
#
# All arguments are forwarded to docker compose after the resolved flags.

set -euo pipefail

# Resolve XCIND_ROOT by following symlinks to the real install directory
# (npm, nix profile, and manual symlinks all route through here). macOS
# lacks `readlink -f`, so the resolver is a manual loop.
# Keep in sync with the equivalent stub in the other bin/ scripts.
__xcind_src="${BASH_SOURCE[0]}"
while [ -L "$__xcind_src" ]; do
  __xcind_src_dir=$(cd "$(dirname "$__xcind_src")" && pwd)
  __xcind_src=$(readlink "$__xcind_src")
  [[ $__xcind_src != /* ]] && __xcind_src="$__xcind_src_dir/$__xcind_src"
done
XCIND_ROOT="$(cd "$(dirname "$__xcind_src")/.." && pwd)"
unset __xcind_src __xcind_src_dir
# shellcheck disable=SC1091
source "$XCIND_ROOT/lib/xcind/xcind-bootstrap.bash"

if [[ ${1:-} == "--version" ]] || [[ ${1:-} == "-V" ]] || [[ ${1:-} == "--xcind-version" ]]; then
  echo "xcind-compose ${XCIND_VERSION}"
  exit 0
fi

if [[ ${1:-} == "--help" ]] || [[ ${1:-} == "-h" ]]; then
  cat <<'HELPEOF'
Usage: xcind-compose [OPTIONS] [DOCKER COMPOSE ARGS...]

Docker Compose wrapper that resolves application config from .xcind.sh.

Options:
  --version, -V  Show version
  --help, -h     Show this help

All other arguments are forwarded to docker compose after resolved flags.

Examples:
  xcind-compose up -d
  xcind-compose build
  xcind-compose exec php bash
  xcind-compose ps
HELPEOF
  exit 0
fi

# Gentle nudge if jq/yq aren't on PATH (silent in scripts and CI).
__xcind-maybe-warn-deps

# --- Main ---

# Run the app-resolution pipeline (shared with xcind-config). Runs in the
# current shell so callers see the populated XCIND_DOCKER_COMPOSE_OPTS.
__xcind-prepare-app || exit 1

# Run EXECUTE hooks (not cached)
if [[ ${#XCIND_HOOKS_EXECUTE[@]} -gt 0 ]]; then
  __xcind-run-execute-hooks "$XCIND_APP_ROOT"
fi

# Execute docker compose with resolved options + passthrough args
exec docker compose "${XCIND_DOCKER_COMPOSE_OPTS[@]}" "$@"
