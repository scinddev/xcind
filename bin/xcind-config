#!/usr/bin/env bash
# xcind-config — Dump resolved xcind configuration
#
# Usage:
#   xcind-config                                           Show help
#   xcind-config --json                                    JSON output (for JetBrains plugin, scripts)
#   xcind-config --preview [-- ARGS...]                    Show the docker compose command
#   xcind-config --check                                   Check system dependencies
#   xcind-config --generate-docker-wrapper[=FILE]          Generate a POSIX docker wrapper
#   xcind-config --generate-docker-compose-wrapper[=FILE]  Generate a POSIX docker-compose wrapper
#   xcind-config --generate-docker-compose-configuration[=FILE]  Generate resolved compose config

set -euo pipefail

# Resolve XCIND_ROOT by following symlinks to the real install directory
# (npm, nix profile, and manual symlinks all route through here). macOS
# lacks `readlink -f`, so the resolver is a manual loop.
# Keep in sync with the equivalent stub in the other bin/ scripts.
__xcind_src="${BASH_SOURCE[0]}"
while [ -L "$__xcind_src" ]; do
  __xcind_src_dir=$(cd "$(dirname "$__xcind_src")" && pwd)
  __xcind_src=$(readlink "$__xcind_src")
  [[ $__xcind_src != /* ]] && __xcind_src="$__xcind_src_dir/$__xcind_src"
done
XCIND_ROOT="$(cd "$(dirname "$__xcind_src")/.." && pwd)"
unset __xcind_src __xcind_src_dir
# shellcheck disable=SC1091
source "$XCIND_ROOT/lib/xcind/xcind-bootstrap.bash"

# --- Helpers ---

__xcind_config_usage() {
  cat <<'HELPEOF'
Usage: xcind-config [OPTIONS]

Options:
  --help, -h                            Show this help
  --version, -V                         Show version
  --check                               Check required/optional dependencies
  doctor [--json]                       Diagnose XCIND_PROXY_EXPORTS / assigned-hook state

  --json                                Output resolved config as JSON
  --preview [-- ARGS...]                Show docker compose command

  --generate-docker-wrapper[=FILE]             Generate docker wrapper script
  --generate-docker-compose-wrapper[=FILE]     Generate docker-compose wrapper script
  --generate-docker-compose-configuration[=FILE]  Generate resolved compose config

  completion {bash|zsh}                        Output shell completion script

Multiple --generate-* flags may be combined when each specifies a file.
Combine with --json to also output JSON to stdout.

Set XCIND_DEBUG=1 to enable trace logging throughout the hook pipeline.
HELPEOF
}

__xcind_config_die() {
  echo "Error: $1" >&2
  echo "Run 'xcind-config --help' for usage." >&2
  exit 1
}

__xcind_config_claim_stdout() {
  local action="$1"
  if [[ -n $_stdout_claim ]]; then
    __xcind_config_die "cannot combine --${action} (stdout) with --${_stdout_claim} (stdout); specify a file path for one of them"
  fi
  _stdout_claim="$action"
}

# --- Parse arguments ---

_do_help=false
_do_version=false
_do_check=false
_do_doctor=false
_doctor_mode="text"
_do_json=false
_do_preview=false
_do_gen_docker_wrapper=false
_gen_docker_wrapper_file=""
_do_gen_compose_wrapper=false
_gen_compose_wrapper_file=""
_do_gen_compose_config=false
_gen_compose_config_file=""
_do_completion=""
_stdout_claim=""
_action_count=0
PREVIEW_EXTRA_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
  --help | -h)
    _do_help=true
    _action_count=$((_action_count + 1))
    ;;
  --version | -V)
    _do_version=true
    _action_count=$((_action_count + 1))
    ;;
  --check)
    _do_check=true
    _action_count=$((_action_count + 1))
    ;;
  --json)
    _do_json=true
    _action_count=$((_action_count + 1))
    __xcind_config_claim_stdout "json"
    ;;
  --preview)
    _do_preview=true
    _action_count=$((_action_count + 1))
    __xcind_config_claim_stdout "preview"
    ;;
  --generate-docker-wrapper=*)
    _do_gen_docker_wrapper=true
    _gen_docker_wrapper_file="${1#*=}"
    if [[ -z $_gen_docker_wrapper_file ]]; then
      __xcind_config_die "--generate-docker-wrapper= requires a file path (use --generate-docker-wrapper without = for stdout)"
    fi
    _action_count=$((_action_count + 1))
    ;;
  --generate-docker-wrapper)
    _do_gen_docker_wrapper=true
    # Check if next arg is a value (not a flag)
    if [[ $# -ge 2 && ${2:0:1} != "-" ]]; then
      shift
      _gen_docker_wrapper_file="$1"
    else
      __xcind_config_claim_stdout "generate-docker-wrapper"
    fi
    _action_count=$((_action_count + 1))
    ;;
  --generate-docker-compose-wrapper=*)
    _do_gen_compose_wrapper=true
    _gen_compose_wrapper_file="${1#*=}"
    if [[ -z $_gen_compose_wrapper_file ]]; then
      __xcind_config_die "--generate-docker-compose-wrapper= requires a file path (use --generate-docker-compose-wrapper without = for stdout)"
    fi
    _action_count=$((_action_count + 1))
    ;;
  --generate-docker-compose-wrapper)
    _do_gen_compose_wrapper=true
    # Check if next arg is a value (not a flag)
    if [[ $# -ge 2 && ${2:0:1} != "-" ]]; then
      shift
      _gen_compose_wrapper_file="$1"
    else
      __xcind_config_claim_stdout "generate-docker-compose-wrapper"
    fi
    _action_count=$((_action_count + 1))
    ;;
  --generate-docker-compose-configuration=*)
    _do_gen_compose_config=true
    _gen_compose_config_file="${1#*=}"
    if [[ -z $_gen_compose_config_file ]]; then
      __xcind_config_die "--generate-docker-compose-configuration= requires a file path (use --generate-docker-compose-configuration without = for stdout)"
    fi
    _action_count=$((_action_count + 1))
    ;;
  --generate-docker-compose-configuration)
    _do_gen_compose_config=true
    # Check if next arg is a value (not a flag)
    if [[ $# -ge 2 && ${2:0:1} != "-" ]]; then
      shift
      _gen_compose_config_file="$1"
    else
      __xcind_config_claim_stdout "generate-docker-compose-configuration"
    fi
    _action_count=$((_action_count + 1))
    ;;
  completion)
    shift
    case "${1:-}" in
    bash) _do_completion="bash" ;;
    zsh) _do_completion="zsh" ;;
    "") __xcind_config_die "completion requires a shell argument: bash or zsh" ;;
    *) __xcind_config_die "unsupported shell: $1 (expected bash or zsh)" ;;
    esac
    _action_count=$((_action_count + 1))
    ;;
  doctor)
    _do_doctor=true
    _action_count=$((_action_count + 1))
    if [[ $# -ge 2 && $2 == "--json" ]]; then
      shift
      _doctor_mode="json"
    fi
    ;;
  --)
    shift
    PREVIEW_EXTRA_ARGS=("$@")
    break
    ;;
  -*)
    __xcind_config_die "unknown option: $1"
    ;;
  *)
    __xcind_config_die "unexpected argument: $1"
    ;;
  esac
  shift
done

# --- Post-parse validation ---

# No actions means help
if [[ $_action_count -eq 0 ]]; then
  _do_help=true
fi

# Standalone actions cannot combine with anything
if [[ $_do_help == true && $_action_count -gt 1 ]]; then
  __xcind_config_die "--help cannot be combined with other options"
fi
if [[ $_do_version == true && $_action_count -gt 1 ]]; then
  __xcind_config_die "--version cannot be combined with other options"
fi
if [[ $_do_check == true && $_action_count -gt 1 ]]; then
  __xcind_config_die "--check cannot be combined with other options"
fi
if [[ $_do_doctor == true && $_action_count -gt 1 ]]; then
  __xcind_config_die "doctor cannot be combined with other options"
fi
if [[ $_do_preview == true && $_action_count -gt 1 ]]; then
  __xcind_config_die "--preview cannot be combined with other options"
fi
if [[ -n $_do_completion && $_action_count -gt 1 ]]; then
  __xcind_config_die "completion cannot be combined with other options"
fi

# -- args only valid with --preview
if [[ ${#PREVIEW_EXTRA_ARGS[@]} -gt 0 && $_do_preview != true ]]; then
  __xcind_config_die "extra arguments after -- are only valid with --preview"
fi

# --- Standalone early-exit actions ---

if [[ $_do_help == true ]]; then
  __xcind_config_usage
  exit 0
fi

if [[ $_do_version == true ]]; then
  echo "xcind-config $(__xcind-version-string)"
  exit 0
fi

if [[ $_do_check == true ]]; then
  __xcind-check-deps
  exit $?
fi

if [[ -n $_do_completion ]]; then
  _completion_file="$XCIND_ROOT/lib/xcind/xcind-completion-${_do_completion}.bash"
  if [[ ! -f $_completion_file ]]; then
    __xcind_config_die "completion script not found: $_completion_file"
  fi
  cat "$_completion_file"
  exit 0
fi

# Gentle nudge if jq/yq aren't on PATH (silent in scripts and CI).
__xcind-maybe-warn-deps

# --- Main pipeline (shared with xcind-compose) ---

# Runs in the current shell so XCIND_DOCKER_COMPOSE_OPTS and related
# globals are visible to the action handlers below.
__xcind-prepare-app || exit 1
app_root="$XCIND_APP_ROOT"

# Resolve the xcind bin directory as seen by the current shell.
# This captures the user-facing path (e.g. ~/.nix-profile/bin) rather than
# the symlink-resolved path, so the wrapper works even when the caller's
# PATH does not include the Nix store or other non-standard locations.
__xcind_bin_dir() {
  local xcind_compose_path
  if xcind_compose_path=$(command -v xcind-compose 2>/dev/null); then
    dirname "$xcind_compose_path"
  else
    echo "$XCIND_ROOT/bin"
  fi
}

# --- Execute actions ---

if [[ $_do_preview == true ]]; then
  __xcind-preview-command "$app_root" "${PREVIEW_EXTRA_ARGS[@]}"
fi

# Resolve the bin dir once: both wrapper generators embed the same path
# and the function forks `command -v` on every call.
_xcind_bin_dir_cached=""
if [[ $_do_gen_docker_wrapper == true || $_do_gen_compose_wrapper == true ]]; then
  _xcind_bin_dir_cached=$(__xcind_bin_dir)
fi

if [[ $_do_gen_docker_wrapper == true ]]; then
  if [[ -n $_gen_docker_wrapper_file ]]; then
    __xcind-dump-docker-wrapper "$app_root" "$_xcind_bin_dir_cached" >"$_gen_docker_wrapper_file"
  else
    __xcind-dump-docker-wrapper "$app_root" "$_xcind_bin_dir_cached"
  fi
fi

if [[ $_do_gen_compose_wrapper == true ]]; then
  if [[ -n $_gen_compose_wrapper_file ]]; then
    __xcind-dump-docker-compose-wrapper "$app_root" "$_xcind_bin_dir_cached" >"$_gen_compose_wrapper_file"
  else
    __xcind-dump-docker-compose-wrapper "$app_root" "$_xcind_bin_dir_cached"
  fi
fi

if [[ $_do_gen_compose_config == true ]]; then
  if [[ -n $_gen_compose_config_file ]]; then
    _tmp_file="${_gen_compose_config_file}.tmp"
    mkdir -p -- "$(dirname "$_gen_compose_config_file")"
    if __xcind-dump-docker-compose-configuration >"$_tmp_file"; then
      mv -- "$_tmp_file" "$_gen_compose_config_file"
    else
      rm -f -- "$_tmp_file"
      exit 1
    fi
  else
    __xcind-dump-docker-compose-configuration
  fi
fi

if [[ $_do_json == true ]]; then
  __xcind-resolve-json "$app_root"
fi

if [[ $_do_doctor == true ]]; then
  if [[ $_doctor_mode == "json" ]]; then
    __xcind-doctor --json
  else
    __xcind-doctor
  fi
fi
