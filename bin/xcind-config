#!/usr/bin/env bash
# xcind-config — Dump resolved xcind configuration
#
# Usage:
#   xcind-config              # JSON output (for JetBrains plugin, scripts, etc.)
#   xcind-config --preview    # Show the docker compose command that would run
#   xcind-config --files      # List resolved files only (one per line)
#
# The JSON output follows the contract expected by the xcind JetBrains plugin:
# {
#   "appRoot": "/path/to/app",
#   "composeFiles": [...],
#   "envFiles": [...],
#   "bakeFiles": [...]
# }

set -euo pipefail

# Resolve the real path of this script, following symlinks (macOS lacks readlink -f)
__xcind_resolve_link() {
  local target="$1"
  while [ -L "$target" ]; do
    local dir
    dir=$(cd "$(dirname "$target")" && pwd)
    target=$(readlink "$target")
    [[ $target != /* ]] && target="$dir/$target"
  done
  echo "$(cd "$(dirname "$target")" && pwd)/$(basename "$target")"
}

XCIND_ROOT="$(cd "$(dirname "$(__xcind_resolve_link "${BASH_SOURCE[0]}")")" && cd .. && pwd)"

# Source the shared library
# shellcheck disable=SC1091
source "$XCIND_ROOT/lib/xcind/xcind-lib.bash"

# --- Parse arguments ---

MODE="json"
case "${1:-}" in
--preview)
  MODE="preview"
  shift
  ;;
--files)
  MODE="files"
  shift
  ;;
--dump-docker-wrapper)
  MODE="dump-docker-wrapper"
  shift
  ;;
--dump-docker-compose-wrapper)
  MODE="dump-docker-compose-wrapper"
  shift
  ;;
--version | -V)
  echo "xcind-config ${XCIND_VERSION}"
  exit 0
  ;;
--check)
  MODE="check"
  shift
  ;;
--help | -h)
  echo "Usage: xcind-config [--version|--preview|--files|--check|--dump-docker-wrapper|--dump-docker-compose-wrapper|--help]"
  echo ""
  echo "  (default)                    Output resolved configuration as JSON"
  echo "  --preview                    Show the docker compose command that would be executed"
  echo "  --files                      List all resolved files, one per line"
  echo "  --check                      Check whether required and optional dependencies are available"
  echo "  --dump-docker-wrapper        Generate a POSIX docker wrapper script"
  echo "  --dump-docker-compose-wrapper  Generate a POSIX docker-compose wrapper script"
  echo "  --help                       Show this help"
  exit 0
  ;;
esac

# --check runs before app-root detection — it's purely about system tools
if [ "$MODE" = "check" ]; then
  __xcind-check-deps
  exit $?
fi

# --- Main ---

# Step 1: Detect app root
# shellcheck disable=SC2119  # intentionally called with no args
app_root=$(__xcind-app-root) || exit 1
export XCIND_APP_ROOT="$app_root"

# Initialize config file tracking
__XCIND_SOURCED_CONFIG_FILES=()

# Step 2: Discover workspace
__xcind-discover-workspace "$app_root"

# Step 3: Source workspace additional configs
if [[ ${XCIND_WORKSPACELESS:-1} == "0" ]] && [[ -n ${XCIND_WORKSPACE_ROOT:-} ]]; then
  __xcind-source-additional-configs "$XCIND_WORKSPACE_ROOT"
fi

# Step 4: Load application config (overrides workspace settings)
__xcind-load-config "$app_root" || exit 1

# Step 5: Source app additional configs
__xcind-source-additional-configs "$app_root"

# Step 6: Late-bind workspace self-declaration
__xcind-late-bind-workspace

# Step 7: Resolve app name
__xcind-resolve-app "$app_root"

# Step 8: Resolve URL templates
__xcind-resolve-url-templates

# Step 9-10: Resolve files and build compose options
__xcind-build-compose-opts "$app_root"

# Steps 11-14: Only run when hooks are registered
if [[ ${#XCIND_HOOKS_POST_RESOLVE_GENERATE[@]} -gt 0 ]]; then
  # Step 11: Compute SHA
  XCIND_SHA=$(__xcind-compute-sha "$app_root")

  # Step 12: Export pipeline vars
  export XCIND_SHA
  export XCIND_CACHE_DIR="$app_root/.xcind/cache/$XCIND_SHA"
  export XCIND_GENERATED_DIR="$app_root/.xcind/generated/$XCIND_SHA"
  export XCIND_APP XCIND_WORKSPACE XCIND_WORKSPACE_ROOT XCIND_WORKSPACELESS
  export XCIND_APP_URL_TEMPLATE XCIND_ROUTER_TEMPLATE XCIND_WORKSPACE_SERVICE_TEMPLATE
  export XCIND_APP_APEX_URL_TEMPLATE XCIND_APEX_ROUTER_TEMPLATE

  # Step 13: Populate cache
  __xcind-populate-cache "$app_root"

  # Step 14: Run hooks (cache hit = replay, cache miss = execute)
  __xcind-run-hooks "$app_root"
fi

# Resolve the xcind bin directory as seen by the current shell.
# This captures the user-facing path (e.g. ~/.nix-profile/bin) rather than
# the symlink-resolved path, so the wrapper works even when the caller's
# PATH does not include the Nix store or other non-standard locations.
__xcind_bin_dir() {
  local xcind_compose_path
  if xcind_compose_path=$(command -v xcind-compose 2>/dev/null); then
    dirname "$xcind_compose_path"
  else
    echo "$XCIND_ROOT/bin"
  fi
}

case "$MODE" in
json)
  __xcind-resolve-json "$app_root"
  ;;

preview)
  __xcind-preview-command "$app_root" "$@"
  ;;

dump-docker-wrapper)
  __xcind-dump-docker-wrapper "$app_root" "$(__xcind_bin_dir)"
  ;;

dump-docker-compose-wrapper)
  __xcind-dump-docker-compose-wrapper "$app_root" "$(__xcind_bin_dir)"
  ;;

files)
  local_compose_dir="${XCIND_COMPOSE_DIR:+$app_root/$XCIND_COMPOSE_DIR}"
  local_resolve_base="${local_compose_dir:-$app_root}"

  if [ ${#__XCIND_SOURCED_CONFIG_FILES[@]} -gt 0 ]; then
    echo "# Config files:"
    printf '%s\n' "${__XCIND_SOURCED_CONFIG_FILES[@]}"
  fi

  echo "# Compose env files:"
  __xcind-resolve-files "$app_root" "${XCIND_COMPOSE_ENV_FILES[@]}"

  if [[ ${#XCIND_APP_ENV_FILES[@]} -gt 0 ]]; then
    echo "# App env files:"
    __xcind-resolve-files "$app_root" ${XCIND_APP_ENV_FILES[@]+"${XCIND_APP_ENV_FILES[@]}"}
  fi

  echo "# Compose files:"
  _base_compose_files=()
  while IFS= read -r _cf; do
    _base_compose_files+=("$_cf")
    echo "$_cf"
  done < <(__xcind-resolve-files "$local_resolve_base" "${XCIND_COMPOSE_FILES[@]}")

  # Include hook-generated compose files
  _i=0
  while [ "$_i" -lt "${#XCIND_DOCKER_COMPOSE_OPTS[@]}" ]; do
    if [ "${XCIND_DOCKER_COMPOSE_OPTS[$_i]}" = "-f" ]; then
      _i=$((_i + 1))
      _f="${XCIND_DOCKER_COMPOSE_OPTS[$_i]}"
      _dup=false
      for _cf in "${_base_compose_files[@]+"${_base_compose_files[@]}"}"; do
        if [ "$_cf" = "$_f" ]; then
          _dup=true
          break
        fi
      done
      if [ "$_dup" = false ]; then
        echo "$_f"
      fi
    fi
    _i=$((_i + 1))
  done

  if [ ${#XCIND_BAKE_FILES[@]} -gt 0 ]; then
    echo "# Bake files:"
    __xcind-resolve-files "$app_root" "${XCIND_BAKE_FILES[@]}"
  fi
  ;;
esac
