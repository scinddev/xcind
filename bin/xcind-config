#!/usr/bin/env bash
# xcind-config — Dump resolved xcind configuration
#
# Usage:
#   xcind-config              # JSON output (for JetBrains plugin, scripts, etc.)
#   xcind-config --preview    # Show the docker compose command that would run
#   xcind-config --files      # List resolved files only (one per line)
#
# The JSON output follows the contract expected by the xcind JetBrains plugin:
# {
#   "projectRoot": "/path/to/project",
#   "composeFiles": [...],
#   "envFiles": [...],
#   "bakeFiles": [...]
# }

set -euo pipefail

# Resolve the real path of this script, following symlinks (macOS lacks readlink -f)
__xcind_resolve_link() {
  local target="$1"
  while [ -L "$target" ]; do
    local dir
    dir=$(cd "$(dirname "$target")" && pwd)
    target=$(readlink "$target")
    [[ $target != /* ]] && target="$dir/$target"
  done
  echo "$(cd "$(dirname "$target")" && pwd)/$(basename "$target")"
}

XCIND_ROOT="$(cd "$(dirname "$(__xcind_resolve_link "${BASH_SOURCE[0]}")")" && cd .. && pwd)"

# Source the shared library
# shellcheck disable=SC1091
source "$XCIND_ROOT/lib/xcind/xcind-lib.bash"

# --- Parse arguments ---

MODE="json"
case "${1:-}" in
--preview)
  MODE="preview"
  shift
  ;;
--files)
  MODE="files"
  shift
  ;;
--version | -V)
  echo "xcind-config ${XCIND_VERSION}"
  exit 0
  ;;
--help | -h)
  echo "Usage: xcind-config [--version|--preview|--files|--help]"
  echo ""
  echo "  (default)    Output resolved configuration as JSON"
  echo "  --preview    Show the docker compose command that would be executed"
  echo "  --files      List all resolved files, one per line"
  echo "  --help       Show this help"
  exit 0
  ;;
esac

# --- Main ---

# Detect app root
app_root=$(__xcind-app-root) || exit 1

# Load project config
__xcind-load-config "$app_root" || exit 1

case "$MODE" in
json)
  __xcind-resolve-json "$app_root"
  ;;

preview)
  __xcind-preview-command "$app_root" "$@"
  ;;

files)
  local_compose_dir="${XCIND_COMPOSE_DIR:+$app_root/$XCIND_COMPOSE_DIR}"
  local_resolve_base="${local_compose_dir:-$app_root}"

  echo "# Env files:"
  __xcind-resolve-files "$app_root" "${XCIND_ENV_FILES[@]}"

  echo "# Compose files:"
  __xcind-resolve-files "$local_resolve_base" "${XCIND_COMPOSE_FILES[@]}"

  if [ ${#XCIND_BAKE_FILES[@]} -gt 0 ]; then
    echo "# Bake files:"
    __xcind-resolve-files "$app_root" "${XCIND_BAKE_FILES[@]}"
  fi
  ;;
esac
