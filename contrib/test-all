#!/usr/bin/env bash
set -Eeuo pipefail

DIR=$(cd "$(dirname "${0}")" && pwd)
PROJECT_ROOT=$(cd "$DIR/.." && pwd)

# --- Constants (pinned to match CI) ---

SHFMT_IMAGE="mvdan/shfmt:v3.10.0"
SHELLCHECK_IMAGE="koalaman/shellcheck:v0.11.0"
BASH_VERSIONS=("3.2" "4.0" "4.4" "5.0" "5.1" "5" "latest")
SHELL_FILES=(bin/xcind-application bin/xcind-compose bin/xcind-config bin/xcind-proxy bin/xcind-workspace lib/xcind/xcind-app-lib.bash lib/xcind/xcind-app-env-lib.bash lib/xcind/xcind-assigned-lib.bash lib/xcind/xcind-bootstrap.bash lib/xcind/xcind-completion-bash.bash lib/xcind/xcind-completion-zsh.bash lib/xcind/xcind-host-gateway-lib.bash lib/xcind/xcind-lib.bash lib/xcind/xcind-naming-lib.bash lib/xcind/xcind-proxy-lib.bash lib/xcind/xcind-registry-lib.bash lib/xcind/xcind-workspace-lib.bash test/test-xcind.sh test/test-xcind-proxy.sh test/lib/assert.sh test/lib/setup.sh install.sh uninstall.sh)

# --- Color support ---

if [ -t 1 ]; then
  GREEN=$'\033[32m'
  RED=$'\033[31m'
  BOLD=$'\033[1m'
  RESET=$'\033[0m'
else
  GREEN=""
  RED=""
  BOLD=""
  RESET=""
fi

# --- Usage ---

usage() {
  echo "Usage: contrib/test-all [OPTIONS]"
  echo ""
  echo "Run CI checks locally using Docker."
  echo ""
  echo "Options:"
  echo "  --shfmt           Run shfmt formatting check"
  echo "  --shellcheck      Run shellcheck linting"
  echo "  --lint            Run shfmt + shellcheck"
  echo "  --test            Run native tests"
  echo "  --bash-versions   Run Docker bash version matrix"
  echo "  --help            Show this help"
  echo ""
  echo "With no options, all groups are run."
  echo "Multiple flags can be combined: contrib/test-all --shfmt --test"
  exit 0
}

# --- Parse arguments ---

RUN_SHFMT=false
RUN_SHELLCHECK=false
RUN_TEST=false
RUN_BASH_VERSIONS=false
ANY_SELECTED=false

while [ $# -gt 0 ]; do
  case "$1" in
  --shfmt)
    RUN_SHFMT=true
    ANY_SELECTED=true
    ;;
  --shellcheck)
    RUN_SHELLCHECK=true
    ANY_SELECTED=true
    ;;
  --lint)
    RUN_SHFMT=true
    RUN_SHELLCHECK=true
    ANY_SELECTED=true
    ;;
  --test)
    RUN_TEST=true
    ANY_SELECTED=true
    ;;
  --bash-versions)
    RUN_BASH_VERSIONS=true
    ANY_SELECTED=true
    ;;
  --help) usage ;;
  *)
    echo "Unknown option: $1"
    exit 1
    ;;
  esac
  shift
done

# Run everything if nothing was explicitly selected
if [ "$ANY_SELECTED" = false ]; then
  RUN_SHFMT=true
  RUN_SHELLCHECK=true
  RUN_TEST=true
  RUN_BASH_VERSIONS=true
fi

# --- Results tracking ---

RESULTS_NAMES=()
RESULTS_STATUS=()
FAILURES=0

record_result() {
  RESULTS_NAMES+=("$1")
  if [ "$2" -eq 0 ]; then
    RESULTS_STATUS+=("PASS")
  else
    RESULTS_STATUS+=("FAIL")
    FAILURES=$((FAILURES + 1))
  fi
}

# --- Test groups ---

run_shfmt() {
  echo "${BOLD}=== shfmt ===${RESET}"
  local rc=0
  docker run --rm -v "$PROJECT_ROOT:/mnt:ro" -w /mnt "$SHFMT_IMAGE" --diff . || rc=$?
  record_result "shfmt" "$rc"
  echo ""
}

run_shellcheck() {
  echo "${BOLD}=== shellcheck ===${RESET}"
  local rc=0
  docker run --rm -v "$PROJECT_ROOT:/mnt:ro" -w /mnt "$SHELLCHECK_IMAGE" "${SHELL_FILES[@]}" || rc=$?
  record_result "shellcheck" "$rc"
  echo ""
}

run_test() {
  echo "${BOLD}=== test ===${RESET}"
  local rc=0
  bash "$PROJECT_ROOT/test/test-xcind.sh" || rc=$?
  record_result "test" "$rc"
  echo ""

  echo "${BOLD}=== test-proxy ===${RESET}"
  local rc2=0
  bash "$PROJECT_ROOT/test/test-xcind-proxy.sh" || rc2=$?
  record_result "test-proxy" "$rc2"
  echo ""
}

run_bash_versions() {
  for ver in "${BASH_VERSIONS[@]}"; do
    echo "${BOLD}=== bash $ver ===${RESET}"
    local rc=0
    docker build --build-arg "BASHVER=$ver" -t "xcind-test:$ver" "$PROJECT_ROOT" || rc=$?
    if [ "$rc" -eq 0 ]; then
      docker run --rm \
        -v "$PROJECT_ROOT:/opt/xcind:ro" \
        -w /opt/xcind \
        --entrypoint bash \
        "xcind-test:$ver" \
        test/test-xcind.sh || rc=$?
    fi
    record_result "bash $ver" "$rc"
    echo ""
  done
}

# --- Run selected groups ---

if [ "$RUN_SHFMT" = true ]; then run_shfmt; fi
if [ "$RUN_SHELLCHECK" = true ]; then run_shellcheck; fi
if [ "$RUN_TEST" = true ]; then run_test; fi
if [ "$RUN_BASH_VERSIONS" = true ]; then run_bash_versions; fi

# --- Summary ---

echo "${BOLD}=== Summary ===${RESET}"
i=0
while [ "$i" -lt "${#RESULTS_NAMES[@]}" ]; do
  name="${RESULTS_NAMES[$i]}"
  status="${RESULTS_STATUS[$i]}"
  if [ "$status" = "PASS" ]; then
    printf "  %-20s %s\n" "$name" "${GREEN}PASS${RESET}"
  else
    printf "  %-20s %s\n" "$name" "${RED}FAIL${RESET}"
  fi
  i=$((i + 1))
done

echo ""
if [ "$FAILURES" -gt 0 ]; then
  echo "${RED}${FAILURES} group(s) failed.${RESET}"
  exit 1
else
  echo "${GREEN}All passed.${RESET}"
  exit 0
fi
