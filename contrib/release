#!/usr/bin/env bash
set -Eeuo pipefail

DIR=$(cd "$(dirname "${0}")" && pwd)
PROJECT_ROOT=$(cd "$DIR/.." && pwd)

usage() {
  echo "Usage: release --major | --minor | --patch"
  exit 1
}

# --- Parse arguments ---

BUMP=""
case "${1:-}" in
--major) BUMP="major" ;;
--minor) BUMP="minor" ;;
--patch) BUMP="patch" ;;
*) usage ;;
esac

# --- Read current version ---

CURRENT_VERSION=$(jq -r .version "$PROJECT_ROOT/package.json")

IFS='.' read -r MAJOR MINOR PATCH <<<"$CURRENT_VERSION"

# --- Compute new version ---

case "$BUMP" in
major)
  MAJOR=$((MAJOR + 1))
  MINOR=0
  PATCH=0
  ;;
minor)
  MINOR=$((MINOR + 1))
  PATCH=0
  ;;
patch)
  PATCH=$((PATCH + 1))
  ;;
esac

NEW_VERSION="${MAJOR}.${MINOR}.${PATCH}"

echo "Bumping version: ${CURRENT_VERSION} -> ${NEW_VERSION}"

# --- Update files ---

# package.json
sed -i'' -e "s/\"version\": \"${CURRENT_VERSION}\"/\"version\": \"${NEW_VERSION}\"/" \
  "$PROJECT_ROOT/package.json"

# lib/xcind/xcind-lib.bash
sed -i'' -e "s/XCIND_VERSION=\"${CURRENT_VERSION}\"/XCIND_VERSION=\"${NEW_VERSION}\"/" \
  "$PROJECT_ROOT/lib/xcind/xcind-lib.bash"

# Dockerfile
sed -i'' -e "s/org.opencontainers.image.version=\"${CURRENT_VERSION}\"/org.opencontainers.image.version=\"${NEW_VERSION}\"/" \
  "$PROJECT_ROOT/Dockerfile"

# flake.nix
sed -i'' -e "s/version = \"${CURRENT_VERSION}\";/version = \"${NEW_VERSION}\";/" \
  "$PROJECT_ROOT/flake.nix"

# --- Git commit and tag ---

git -C "$PROJECT_ROOT" add \
  package.json \
  lib/xcind/xcind-lib.bash \
  Dockerfile \
  flake.nix

# Generate changelog for only the new (unreleased) commits and prepend
# to the existing CHANGELOG.md.  This preserves previous entries exactly
# as they were written (including attribution) instead of regenerating
# the entire file.
#
# --tag "$new_version" tells git-cliff to treat unreleased commits as
# belonging to this version (since the tag doesn't exist yet).
# --unreleased-only only processes commits since the last tag.
# --prepend inserts the new section at the top of the existing file.
echo "Updating CHANGELOG.md..."
git-cliff --unreleased-only --tag "v${NEW_VERSION}" --prepend CHANGELOG.md

# Stage it alongside the other version-bumped files
git add CHANGELOG.md

git -C "$PROJECT_ROOT" commit -m "release: v${NEW_VERSION}"
git -C "$PROJECT_ROOT" tag -a "v${NEW_VERSION}" -m "v${NEW_VERSION}"

echo ""
echo "Tagged v${NEW_VERSION}. Run: git push --follow-tags"
