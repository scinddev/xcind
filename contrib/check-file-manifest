#!/usr/bin/env bash
# contrib/check-file-manifest — Verify that every file in bin/ and lib/xcind/
# is listed in all installation/packaging/CI manifests.
#
# Exit 0 if everything is consistent, 1 if any manifest is out of sync.
# Designed to run as a pre-commit hook (local repo).
# Compatible with Bash 3.2+ and macOS/BSD utilities.
set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$PROJECT_ROOT"

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

# ---------------------------------------------------------------------------
# 1. Discover the source-of-truth file sets
# ---------------------------------------------------------------------------

find bin -maxdepth 1 -type f -print | sort >"$tmpdir/bin_files"
find lib/xcind -maxdepth 1 -type f -name '*.bash' -print | sort >"$tmpdir/lib_files"
sort "$tmpdir/bin_files" "$tmpdir/lib_files" >"$tmpdir/all_installed"

# ---------------------------------------------------------------------------
# 2. Helper: diff two sorted lists via comm, report missing/extra items
# ---------------------------------------------------------------------------

errors=0

# check_set <label> <expected_file> <actual ...>
#   expected_file: path to a sorted file of expected entries
#   remaining args: the actual entries found in the manifest
check_set() {
  local label="$1"
  local expected_file="$2"
  shift 2

  printf '%s\n' "$@" | sort >"$tmpdir/actual"

  local missing extra
  missing=$(comm -23 "$expected_file" "$tmpdir/actual")
  extra=$(comm -13 "$expected_file" "$tmpdir/actual" | sed 's/^\t//')

  if [ -n "$missing" ] || [ -n "$extra" ]; then
    echo "MISMATCH in $label:"
    if [ -n "$missing" ]; then
      while IFS= read -r f; do
        echo "  - missing: $f"
      done <<EOF
$missing
EOF
    fi
    if [ -n "$extra" ]; then
      while IFS= read -r f; do
        echo "  + extra:   $f"
      done <<EOF
$extra
EOF
    fi
    errors=$((errors + 1))
  fi
}

# ---------------------------------------------------------------------------
# 3. Parse each manifest and compare
# ---------------------------------------------------------------------------

# --- install.sh ---
install_files=()
while IFS= read -r line; do
  # Lines like: install -m 755 "$XCIND_ROOT/bin/xcind-compose" "$PREFIX/bin/xcind-compose"
  if [[ $line =~ \$XCIND_ROOT/(bin/[^\"]+)\" ]]; then
    install_files+=("${BASH_REMATCH[1]}")
  elif [[ $line =~ \$XCIND_ROOT/(lib/xcind/[^\"]+)\" ]]; then
    install_files+=("${BASH_REMATCH[1]}")
  fi
done <install.sh
check_set "install.sh" "$tmpdir/all_installed" "${install_files[@]}"

# --- uninstall.sh ---
uninstall_files=()
while IFS= read -r line; do
  if [[ $line =~ \$PREFIX/(bin/[^\"]+)\" ]]; then
    uninstall_files+=("${BASH_REMATCH[1]}")
  elif [[ $line =~ \$PREFIX/(lib/xcind/[^\"]+)\" ]]; then
    uninstall_files+=("${BASH_REMATCH[1]}")
  fi
done <uninstall.sh
check_set "uninstall.sh" "$tmpdir/all_installed" "${uninstall_files[@]}"

# --- package.json "bin" field (bin/ executables only) ---
pkg_bin_files=()
while IFS= read -r val; do
  pkg_bin_files+=("$val")
done < <(
  # Extract values from the "bin" object in package.json
  python3 -c "
import json, sys
with open('package.json') as f:
    data = json.load(f)
for v in sorted(data.get('bin', {}).values()):
    print(v)
" 2>/dev/null ||
    # Fallback: parse with grep if python3 is unavailable (avoid non-portable -P)
    grep -oE ':[[:space:]]*"(bin/[^"]+)"' package.json | sed 's/.*"\(bin\/[^"]*\)".*/\1/' | sort
)
check_set "package.json bin" "$tmpdir/bin_files" "${pkg_bin_files[@]}"

# --- flake.nix postInstall wrapProgram (bin/ executables only) ---
flake_bin_files=()
while IFS= read -r line; do
  if [[ $line =~ wrapProgram.*/bin/([^\"[:space:]\\]+) ]]; then
    flake_bin_files+=("bin/${BASH_REMATCH[1]}")
  fi
done <flake.nix
check_set "flake.nix wrapProgram" "$tmpdir/bin_files" "${flake_bin_files[@]}"

# --- Makefile SHELL_FILES (all shell scripts) ---
makefile_files=()
in_array=false
while IFS= read -r line; do
  if [[ $line =~ ^SHELL_FILES[[:space:]]*= ]]; then
    in_array=true
    line="${line#*=}"
  fi
  if [ "$in_array" = true ]; then
    # Strip trailing backslash and surrounding whitespace, then split on IFS
    stripped="${line%\\}"
    for token in $stripped; do
      case "$token" in
      bin/* | lib/xcind/*) makefile_files+=("$token") ;;
      esac
    done
    # End of array when the line does not continue with a trailing backslash
    [[ $line != *\\ ]] && in_array=false
  fi
done <Makefile
check_set "Makefile SHELL_FILES" "$tmpdir/all_installed" "${makefile_files[@]}"

# --- contrib/test-all SHELL_FILES (all shell scripts) ---
testall_files=()
while IFS= read -r line; do
  if [[ $line =~ SHELL_FILES=\( ]]; then
    # Extract the array content — may span one line
    content="${line#*SHELL_FILES=(}"
    content="${content%)}"
    for token in $content; do
      case "$token" in
      bin/* | lib/xcind/*) testall_files+=("$token") ;;
      esac
    done
  fi
done <contrib/test-all
check_set "contrib/test-all SHELL_FILES" "$tmpdir/all_installed" "${testall_files[@]}"

# --- .github/workflows/tests.yml shellcheck step ---
ci_files=()
in_shellcheck=false
while IFS= read -r line; do
  # Detect the shellcheck run block
  # shellcheck disable=SC1003  # backslash is literal in glob pattern
  if [[ $line == *'shellcheck \'* ]]; then
    in_shellcheck=true
    continue
  fi
  if [ "$in_shellcheck" = true ]; then
    trimmed="${line#"${line%%[![:space:]]*}"}"
    # Determine whether this is still a continuation line (ends with \)
    is_continuation=false
    # shellcheck disable=SC1003  # backslash is literal in glob pattern
    [[ $trimmed == *'\' ]] && is_continuation=true
    # Strip trailing backslash and any trailing whitespace
    path="${trimmed% \\}"
    path="${path%\\}"
    path="${path%% *}"
    # Collect only bin/ and lib/xcind/ paths; skip other entries (test/, install.sh, …)
    # but keep scanning the whole block so ordering doesn't matter.
    case "$path" in
    bin/* | lib/xcind/*) ci_files+=("$path") ;;
    esac
    # End collection once we leave the continuation block
    if [ "$is_continuation" = false ]; then
      in_shellcheck=false
    fi
  fi
done <.github/workflows/tests.yml
check_set ".github/workflows/tests.yml shellcheck" "$tmpdir/all_installed" "${ci_files[@]}"

# ---------------------------------------------------------------------------
# 4. Report
# ---------------------------------------------------------------------------

if [ "$errors" -gt 0 ]; then
  echo ""
  echo "Found $errors manifest(s) out of sync with bin/ and lib/xcind/."
  echo "Update the listed files so every installed file is included."
  exit 1
else
  echo "All manifests are in sync."
  exit 0
fi
