{
  "name": "@scinddev/xcind",
  "version": "0.5.0",
  "description": "Slim shell wrapper around docker compose with per-application config",
  "bin": {
    "xcind-app": "bin/xcind-application",
    "xcind-application": "bin/xcind-application",
    "xcind-compose": "bin/xcind-compose",
    "xcind-config": "bin/xcind-config",
    "xcind-proxy": "bin/xcind-proxy",
    "xcind-workspace": "bin/xcind-workspace"
  },
  "files": [
    "bin",
    "lib",
    "install.sh",
    "uninstall.sh"
  ],
  "directories": {
    "bin": "bin",
    "lib": "lib",
    "test": "test"
  },
  "scripts": {
    "postinstall": "command -v xcind-config >/dev/null 2>&1 && xcind-config --check || true",
    "test": "test/test-xcind.sh"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scinddev/xcind.git"
  }
}
